{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Turnleaf",
  "version": "1.0.0",
  "identifier": "dev.turnleaf.app",
  "build": {
    "frontendDist": "../src/gui/public",
    "beforeBuildCommand": "npm run stage"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Turnleaf",
        "width": 1200,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "visible": false,
        "decorations": false,
        "dragDropEnabled": false,
        "url": "loading.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../dist/home": "home"
    }
  }
}
